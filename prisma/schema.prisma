generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(CANDIDATE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company[]

  refreshTokens       RefreshToken[]
  applications        Application[]
  resumes             Resume[]
  activities          ApplicationActivity[]
  applicationNotes    ApplicationNote[]
  activityLogs        ActivityLog[]
  candidateInterviews Interview[]           @relation("CandidateInterviews")
  scheduledInterviews Interview[]           @relation("ScheduledInterviews")
  createdInterviews   Interview[]           @relation("InterviewCreator")
  updatedInterviews   Interview[]           @relation("InterviewUpdater")

  interviewFeedbacks InterviewFeedback[]
  interviewHistories InterviewHistory[]
  candidateOffers    Offer[]             @relation("CandidateOffers")
  createdOffers      Offer[]             @relation("CreatedOffers")
  updatedOffers      Offer[]             @relation("UpdatedOffers")
  approvedOffers     Offer[]             @relation("ApprovedOffers")
  sentOffers         Offer[]             @relation("SentOffers")
  revokedOffers      Offer[]             @relation("RevokedOffers")
  performedTimelines OfferTimeline[]
  performedAuditLogs OfferAuditLog[]
  notifications      Notification[]
  notificationPreference NotificationPreference?
  createdAssessments Assessment[]        @relation("AssessmentCreator")
  assessmentAttempts AssessmentAttempt[]
  leaderboardEntries Leaderboard[]
  behaviours         AssessmentBehaviour[]
  createdInterviewTemplates InterviewTemplate[]
  interviewNotes     InterviewNote[]
  participantSessions InterviewParticipant[]
  interviewerScorecards InterviewScorecard[] @relation("InterviewerScorecards")
  candidateScorecards   InterviewScorecard[] @relation("CandidateScorecards")
  candidateHiringDecisions HiringDecision[]   @relation("CandidateHiringDecisions")
  createdHiringDecisions   HiringDecision[]   @relation("CreatedHiringDecisions")
  decisionApprovals        DecisionApproval[]
  decisionComments         DecisionComment[]
  decisionHistories        DecisionHistory[]
  decisionAudits           DecisionAudit[]
  candidateOnboardings     OnboardingRecord[]        @relation("CandidateOnboardings")
  hrOnboardings            OnboardingRecord[]        @relation("HROnboardings")
  managerOnboardings       OnboardingRecord[]        @relation("ManagerOnboardings")
  employeeProfile          EmployeeProfile?          @relation("UserProfile")
  managedEmployees         EmployeeProfile[]         @relation("ManagerEmployees")
  lifecycleHistoryChanges  EmployeeLifecycleHistory[]
  assignedTasks            OnboardingTask[]          @relation("AssignedTasks")
  completedTasks           OnboardingTask[]          @relation("CompletedTasks")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  email              String?
  phone              String?
  website            String?
  industry           String?
  companySize        CompanySize
  logo               String?
  description        String?
  ownerId            String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  careerPagePublic   Boolean        @default(true)
  currency           String         @default("USD")
  dateFormat         String         @default("YYYY-MM-DD")
  defaultHiringStage String         @default("Applied")
  emailNotifications Boolean        @default(true)
  language           String         @default("en")
  smsNotifications   Boolean        @default(false)
  timeFormat         String         @default("24h")
  timezone           String         @default("UTC")
  owner              User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hrs                HR[]
  jobs               Job[]
  activityLogs       ActivityLog[]
  interviews         Interview[]
  offers             Offer[]
  notifications      Notification[]
  notificationPreferences NotificationPreference[]
  assessments        Assessment[]
  questionCategories QuestionCategory[]
  interviewQuestions InterviewQuestion[]
  interviewTemplates InterviewTemplate[]
  evaluationCriteria EvaluationCriteria[]
  interviewSessions  InterviewSession[]
  interviewScorecards InterviewScorecard[]
  aiAnalyses         InterviewAIAnalysis[]
  hiringDecisions    HiringDecision[]
  onboardingRecords  OnboardingRecord[]
  employeeProfiles   EmployeeProfile[]
  onboardingTaskTemplates OnboardingTaskTemplate[]
}

model HR {
  id                     String    @id @default(uuid())
  firstName              String
  lastName               String
  email                  String    @unique
  phone                  String
  designation            String
  password               String
  role                   Role      @default(HR)
  status                 String    @default("ACTIVE")
  isActive               Boolean   @default(true)
  lastLoginAt            DateTime?
  avatar                 String?
  companyId              String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?
  refreshToken           String?
  refreshTokenExpiresAt  DateTime?
  tokenVersion           Int       @default(1)
  lastLogoutAt           DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  passwordChangedAt      DateTime?
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR
  CANDIDATE
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum HRStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Job {
  id                  String         @id @default(uuid())
  companyId           String
  createdBy           String
  title               String
  department          String
  employmentType      EmploymentType
  experienceLevel     String?
  location            String
  workMode            WorkMode
  salaryMin           Float?
  salaryMax           Float?
  currency            String         @default("USD")
  description         String
  requirements        String
  benefits            String?
  status              JobStatus      @default(DRAFT)
  publishedAt         DateTime?
  closedAt            DateTime?
  applicationDeadline DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  interviews   Interview[]
  offers       Offer[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([closedAt])
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum ApplicationSource {
  CAREERS_PAGE
  COMPANY_WEBSITE
  LINKEDIN
  NAUKRI
  INDEED
  REFERRAL
  CONSULTANCY
  CAMPUS
  MANUAL
  OTHER
}

model Application {
  id          String            @id @default(uuid())
  candidateId String
  jobId       String
  resumeId    String?
  status      ApplicationStatus @default(APPLIED)
  source      ApplicationSource @default(CAREERS_PAGE)
  resumeUrl   String?
  coverLetter String?
  appliedAt   DateTime          @default(now())
  withdrawnAt DateTime?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  candidate    User                  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job          Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume       Resume?               @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  activities   ApplicationActivity[]
  notes        ApplicationNote[]
  interviews   Interview[]
  offer        Offer?
  hiringDecisions HiringDecision[]

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@index([jobId, status]) // Analytics Index
  @@index([jobId, source]) // Analytics Index
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum ParsingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiScoreStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Resume {
  id           String  @id @default(uuid())
  candidateId  String
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  storageKey   String  @unique
  fileUrl      String
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parsedData    Json?
  parsingStatus ParsingStatus @default(PENDING)
  parsedAt      DateTime?
  parserVersion String?
  parsingError  String?

  aiScore          Int?
  aiScoreVersion   String?
  aiScoreStatus    AiScoreStatus @default(PENDING)
  aiScoredAt       DateTime?
  aiScoreBreakdown Json?
  scoringProvider  String?

  candidate    User          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([candidateId, isActive, deletedAt]) // Optimized lookup for active candidate resumes
  @@index([createdAt]) // Optimized for date filtering
  @@index([parsingStatus]) // Optimized for parsing queues/status filtering
  @@index([parsedData], type: Gin) // Optimized for JSONB full-text and array searches
}

enum ApplicationActivityAction {
  APPLICATION_CREATED
  APPLICATION_WITHDRAWN
  STATUS_CHANGED
  INTERVIEW_SCHEDULED
  INTERVIEW_RESCHEDULED
  INTERVIEW_CANCELLED
  INTERVIEW_COMPLETED
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_DRAFTED
  OFFER_APPROVED
  OFFER_REVOKED
  OFFER_EXPIRED
  APPLICATION_REJECTED
  APPLICATION_HIRED
  NOTE_ADDED
  RESUME_UPDATED
  PROFILE_UPDATED
  INTERVIEW_FEEDBACK_SUBMITTED
  INTERVIEW_DECISION_UPDATED
}

model ApplicationActivity {
  id            String                    @id @default(uuid())
  applicationId String
  performedBy   String
  action        ApplicationActivityAction
  oldStatus     ApplicationStatus?
  newStatus     ApplicationStatus?
  metadata      Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [performedBy], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([performedBy])
  @@index([action])
  @@index([createdAt])
  @@index([performedBy, createdAt]) // Analytics Index
}

model ApplicationNote {
  id            String @id @default(uuid())
  applicationId String
  authorId      String
  note          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([authorId])
  @@index([createdAt])
}


enum InterviewType {
  ONLINE
  OFFLINE
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum InterviewDecision {
  PENDING
  NEXT_ROUND
  SELECTED
  REJECTED
  ON_HOLD
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  companyId       String
  candidateId     String
  jobId           String
  scheduledById   String
  title           String
  description     String?
  type            InterviewType
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int
  timezone        String
  meetingLink     String?
  location        String?
  notes           String?

  roundNumber       Int       @default(1)
  roundName         String?
  parentInterviewId String?
  sequence          Int       @default(1)
  isFinalRound      Boolean   @default(false)
  templateId        String?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  rescheduledAt     DateTime?

  createdById String?
  updatedById String?

  decision      InterviewDecision @default(PENDING)
  decisionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application     Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate       User                @relation("CandidateInterviews", fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scheduledBy     User                @relation("ScheduledInterviews", fields: [scheduledById], references: [id], onDelete: SetNull)
  createdBy       User?               @relation("InterviewCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?               @relation("InterviewUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  parentInterview Interview?          @relation("InterviewRounds", fields: [parentInterviewId], references: [id], onDelete: Cascade)
  childRounds     Interview[]         @relation("InterviewRounds")
  template        InterviewTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  feedbacks       InterviewFeedback[]
  history         InterviewHistory[]
  session         InterviewSession?

  @@index([applicationId])
  @@index([companyId])
  @@index([candidateId])
  @@index([jobId])
  @@index([scheduledAt])
  @@index([parentInterviewId])
  @@index([status])
  @@index([roundNumber])
  @@index([decision])
  @@index([createdAt])
  @@index([companyId, jobId, status]) // Analytics Index
  @@index([scheduledById]) // Analytics Index
}

enum HiringRecommendation {
  STRONG_HIRE
  HIRE
  HOLD
  NO_HIRE
}

model InterviewFeedback {
  id                  String               @id @default(uuid())
  interviewId         String
  interviewerId       String
  overallRating       Float
  recommendation      HiringRecommendation
  technicalScore      Int?
  communicationScore  Int?
  problemSolvingScore Int?
  cultureFitScore     Int?
  strengths           String?
  weaknesses          String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer User      @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@unique([interviewId, interviewerId])
  @@index([interviewId])
  @@index([interviewerId])
  @@index([recommendation])
  @@index([createdAt])
}

enum InterviewHistoryAction {
  RESCHEDULED
  CANCELLED
  STATUS_CHANGED
}

model InterviewHistory {
  id             String                 @id @default(uuid())
  interviewId    String
  action         InterviewHistoryAction
  oldScheduledAt DateTime?
  newScheduledAt DateTime?
  oldStatus      InterviewStatus?
  newStatus      InterviewStatus?
  reason         String
  performedById  String
  metadata       Json?
  createdAt      DateTime               @default(now())

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  performedBy User      @relation(fields: [performedById], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([performedById])
}

enum OfferStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

model Offer {
  id            String      @id @default(uuid())
  applicationId String      @unique
  companyId     String
  candidateId   String
  jobId         String
  status        OfferStatus @default(DRAFT)

  jobTitle         String
  department       String
  employmentType   EmploymentType
  salary           Float
  currency         String         @default("USD")
  joiningDate      DateTime
  location         String
  reportingManager String
  notes            String?
  validUntil       DateTime

  createdById  String
  updatedById  String?
  approvedById String?
  sentById     String?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?
  approvedAt               DateTime?
  sentAt                   DateTime?
  acceptedAt               DateTime?
  rejectedAt               DateTime?
  candidateResponseMessage String?
  rejectionReason          String?
  expiredAt                DateTime?
  revokedAt                DateTime?
  revokedById              String?
  revocationReason         String?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate   User        @relation("CandidateOffers", fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("CreatedOffers", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User?       @relation("UpdatedOffers", fields: [updatedById], references: [id], onDelete: Restrict)
  approvedBy  User?       @relation("ApprovedOffers", fields: [approvedById], references: [id], onDelete: SetNull)
  sentBy      User?       @relation("SentOffers", fields: [sentById], references: [id], onDelete: SetNull)
  revokedBy   User?       @relation("RevokedOffers", fields: [revokedById], references: [id], onDelete: SetNull)

  timelines OfferTimeline[]
  auditLogs OfferAuditLog[]
  onboardingRecord OnboardingRecord?

  @@index([companyId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([validUntil])
  @@index([deletedAt])
  @@index([companyId, jobId, status]) // Analytics Index
  @@index([createdById]) // Analytics Index
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String   @id @default(uuid())
  role         Role
  permissionId String
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

model OfferTimeline {
  id              String   @id @default(uuid())
  offerId         String
  type            String
  title           String
  description     String
  performedById   String?
  performedByRole String?
  createdAt       DateTime @default(now())

  offer       Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  performedBy User? @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([performedById])
}

model OfferAuditLog {
  id              String   @id @default(uuid())
  offerId         String
  action          String
  performedById   String?
  performedByRole String?
  field           String?
  oldValue        String?
  newValue        String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  offer       Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  performedBy User? @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([performedById])
}

enum NotificationType {
  INTERVIEW
  OFFER
  APPLICATION
  JOB
  AUTH
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
  PUSH
  WHATSAPP
  SLACK
}

enum NotificationStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  FAILED
  RETRYING
  CANCELLED
  READ
}

model Notification {
  id        String              @id @default(uuid())
  companyId String
  userId    String
  type      NotificationType
  channel   NotificationChannel
  title     String
  message   String
  status    NotificationStatus  @default(PENDING)
  payload   Json?
  isRead        Boolean             @default(false)
  
  // --- Email Engine Tracking Fields ---
  provider          String?
  messageId         String?
  providerResponse  String?
  failureReason     String?
  retryCount        Int                 @default(0)
  queuedAt          DateTime?
  processingAt      DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  lastRetryAt       DateTime?
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([isRead])
}

model NotificationPreference {
  id               String    @id @default(uuid())
  userId           String    @unique
  companyId        String
  emailEnabled     Boolean   @default(true)
  inAppEnabled     Boolean   @default(true)
  smsEnabled       Boolean   @default(false)
  pushEnabled      Boolean   @default(false)
  whatsappEnabled  Boolean   @default(false)
  marketingEnabled Boolean   @default(false)
  systemEnabled    Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

enum ActivityEntity {
  AUTH
  COMPANY
  HR
  JOB
  APPLICATION
  INTERVIEW
  OFFER
  NOTIFICATION
  SYSTEM
  RESUME
  ASSESSMENT
  ONBOARDING
  EMPLOYEE_PROFILE
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  ASSIGN
  LOGIN
  LOGOUT
  PASSWORD_RESET
  APPLY
  WITHDRAW
  STATUS_CHANGE
  SCHEDULE
  RESCHEDULE
  CANCEL
  FEEDBACK
  APPROVE
  SEND
  ACCEPT
  REJECT
  PUBLISH
  CLOSE
  PREVIEW
  DOWNLOAD
  PARSE
  REPARSE
  PARSE_FAILED
  SEARCH
  SCORE
  RE_SCORE
  GENERATE
  START
  PAUSE
  RESUME
  SUBMIT
  FLAG
  VIEW
  COMPLETE
}

model ActivityLog {
  id              String         @id @default(uuid())
  companyId       String?
  userId          String?
  entityType      ActivityEntity
  entityId        String?
  action          ActivityAction
  oldValue        Json?
  newValue        Json?
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  performedByRole Role?

  createdAt       DateTime       @default(now())
  deletedAt       DateTime?
  retentionUntil  DateTime?
  archivedAt      DateTime?

  company         Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@index([retentionUntil])
  @@index([archivedAt])
}

// ==========================================
// ASSESSMENT MODULE
// ==========================================

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  EXPIRED
}

enum GameDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SessionState {
  CREATED
  READY
  RUNNING
  PAUSED
  SUBMITTED
  EXPIRED
  CANCELLED
  CHEAT_FLAGGED
}

enum CheatRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecommendationLevel {
  OUTSTANDING
  HIGHLY_RECOMMENDED
  RECOMMENDED
  AVERAGE
  NOT_RECOMMENDED
}

model Assessment {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String?
  status      AssessmentStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  scoringProfile Json? // Custom weights: { accuracy, efficiency, decisionSpeed, cheatPenalty }

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User     @relation("AssessmentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  games       AssessmentGame[]
  attempts    AssessmentAttempt[]
  behaviours  AssessmentBehaviour[]

  @@index([companyId])
  @@index([status])
}

model AssessmentGame {
  id           String   @id @default(uuid())
  assessmentId String
  gameType     String
  difficulty   GameDifficulty
  timeLimitMs  Int?
  config       Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  results      AssessmentResult[]
  sessions     GameSession[]

  @@index([assessmentId])
  @@index([gameType])
}

model AssessmentAttempt {
  id           String   @id @default(uuid())
  assessmentId String
  candidateId  String
  status           AttemptStatus @default(NOT_STARTED)
  score            Float?
  accuracy         Float?
  efficiency       Float?
  decisionSpeed    Float?
  recommendation   RecommendationLevel?
  scoreBreakdown   Json?
  rank             Int?           // Leaderboard rank snapshot
  
  startedAt        DateTime?
  completedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate    User       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  results      AssessmentResult[]
  sessions     GameSession[]
  behaviour    AssessmentBehaviour?

  @@index([assessmentId])
  @@index([candidateId])
  @@index([status])
  @@index([assessmentId, status, rank])
  @@index([assessmentId, candidateId, status])
}

model AssessmentResult {
  id          String   @id @default(uuid())
  attemptId   String
  gameId      String
  score           Float
  maxScore        Float
  accuracy        Float?
  efficiency      Float?
  decisionSpeed   Float?
  recommendation  RecommendationLevel?
  scoreBreakdown  Json?
  metadata        Json?

  createdAt       DateTime @default(now())

  attempt     AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  game        AssessmentGame    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([gameId])
  @@index([attemptId, score])
}

model GameSession {
  id                String         @id @default(uuid())
  attemptId         String
  gameId            String
  seedId            String?
  status            SessionState   @default(CREATED)
  
  // Anti-Cheat & Tracking
  cheatRiskScore    Int            @default(0)
  cheatRiskLevel    CheatRiskLevel @default(LOW)
  idleTimeMs        Int            @default(0)
  pauseCount        Int            @default(0)
  reconnectCount    Int            @default(0)

  startedAt         DateTime       @default(now())
  endedAt           DateTime?
  submittedAt       DateTime?

  attempt           AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  game              AssessmentGame    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seed              GameSeed?         @relation(fields: [seedId], references: [id], onDelete: SetNull)
  moves             GameMove[]
  cheatEvents       CheatEvent[]

  @@index([attemptId])
  @@index([gameId])
  @@index([attemptId, status])
}

model GameSeed {
  id               String   @id @default(uuid())
  assessmentId     String
  candidateId      String
  gameType         String
  difficulty       GameDifficulty
  
  seedData         Json
  hiddenSolution   Json
  hash             String   
  version          String
  metadata         Json?
  
  isUsed           Boolean  @default(false)
  createdAt        DateTime @default(now())

  sessions         GameSession[]

  @@unique([assessmentId, candidateId, gameType])
  @@index([gameType, difficulty])
  @@index([candidateId])
}

model GameMove {
  id             String      @id @default(uuid())
  sessionId      String
  moveNumber     Int
  action         String
  coordinates    Json?
  moveDurationMs Int
  metadata       Json?
  timestamp      DateTime    @default(now())

  session        GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, moveNumber])
  @@index([sessionId])
}

model CheatEvent {
  id          String      @id @default(uuid())
  sessionId   String
  eventType   String      
  metadata    Json?
  timestamp   DateTime    @default(now())
  
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}

model Leaderboard {
  id          String   @id @default(uuid())
  gameType    String
  candidateId String
  topScore    Float
  attemptsCount Int    @default(1)
  
  updatedAt   DateTime @updatedAt

  candidate   User     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([gameType, candidateId])
  @@index([gameType, topScore(sort: Desc)])
}

model AssessmentBehaviour {
  id                  String   @id @default(uuid())
  attemptId           String   @unique
  assessmentId        String
  candidateId         String

  thinkingSpeed       Float
  decisionQuality     Float
  problemSolving      Float
  planningAbility     Float
  consistency         Float
  riskTaking          Float
  accuracy            Float
  learningPattern     Float
  stressIndicator     Float
  confidenceIndicator Float

  behaviourSummary    Json     // Array of trait strings (e.g. ["Fast Logical Thinker", "High Accuracy"])
  metrics             Json?    // Move & timing metadata breakdown

  analysisVersion     String   @default("v1.0")
  analysisProvider    String   @default("RULE_BASED")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  attempt             AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  assessment          Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate           User              @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([candidateId])
  @@index([assessmentId, candidateId])
}

// ==========================================
// INTERVIEW INTELLIGENCE PLATFORM (PHASE 11)
// ==========================================

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum QuestionType {
  TECHNICAL
  BEHAVIOURAL
  SITUATIONAL
  PROBLEM_SOLVING
  SYSTEM_DESIGN
  HR
  CUSTOM
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model QuestionCategory {
  id          String              @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  questions   InterviewQuestion[]

  @@index([companyId])
}

model InterviewQuestion {
  id             String                 @id @default(uuid())
  companyId      String
  categoryId     String?
  title          String
  questionText   String
  type           QuestionType
  difficulty     QuestionDifficulty     @default(MEDIUM)
  sampleAnswer   String?
  scoringRubric  Json?
  tags           String[]               @default([])
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?

  company        Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category       QuestionCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  templateLinks  TemplateQuestionLink[]

  @@index([companyId])
  @@index([type])
  @@index([difficulty])
}

model InterviewTemplate {
  id                String                 @id @default(uuid())
  companyId         String
  createdById       String
  title             String
  description       String?
  status            TemplateStatus         @default(ACTIVE)
  isDefault         Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?

  company           Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy         User                   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  rounds            InterviewRoundTemplate[]
  criteria          EvaluationCriteria[]
  templateQuestions TemplateQuestionLink[]
  interviews        Interview[]

  @@index([companyId])
  @@index([status])
}

model TemplateQuestionLink {
  id              String                  @id @default(uuid())
  templateId      String
  questionId      String
  roundTemplateId String?
  order           Int                     @default(0)

  template        InterviewTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  question        InterviewQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  roundTemplate   InterviewRoundTemplate? @relation(fields: [roundTemplateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([questionId])
}

model InterviewRoundTemplate {
  id                      String                 @id @default(uuid())
  templateId              String
  roundName               String
  roundType               String
  sequence                Int                    @default(1)
  expectedDurationMinutes Int                    @default(45)
  questionCount           Int                    @default(5)
  passingScore            Float                  @default(70.0)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  template                InterviewTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions               TemplateQuestionLink[]
  criteria                EvaluationCriteria[]

  @@index([templateId])
}

model EvaluationCriteria {
  id              String                  @id @default(uuid())
  companyId       String
  templateId      String?
  roundTemplateId String?
  name            String
  description     String?
  weight          Float                   @default(1.0)
  maxScore        Float                   @default(10.0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template        InterviewTemplate?      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  roundTemplate   InterviewRoundTemplate? @relation(fields: [roundTemplateId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([templateId])
}

// ==========================================
// LIVE INTERVIEW SESSION ENGINE (SPRINT 2)
// ==========================================

enum InterviewSessionState {
  SCHEDULED
  READY
  LIVE
  PAUSED
  COMPLETED
  CANCELLED
  NO_SHOW
  EXPIRED
}

enum ParticipantRole {
  CANDIDATE
  INTERVIEWER
  HR
  OBSERVER
}

enum MeetingProviderType {
  INTERNAL
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  CUSTOM
}

model InterviewSession {
  id                    String                @id @default(uuid())
  interviewId           String?               @unique
  companyId             String
  title                 String
  description           String?
  status                InterviewSessionState @default(SCHEDULED)
  meetingProvider       MeetingProviderType   @default(INTERNAL)
  meetingUrl            String?
  meetingRoomId         String?
  scheduledAt           DateTime
  startedAt             DateTime?
  pausedAt              DateTime?
  resumedAt             DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  durationMinutes       Int                   @default(45)
  actualDurationSeconds Int                   @default(0)
  metadata              Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  interview             Interview?            @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  participants          InterviewParticipant[]
  timeline              InterviewTimeline[]
  events                InterviewEvent[]
  notes                 InterviewNote[]
  scorecards            InterviewScorecard[]
  aiAnalyses            InterviewAIAnalysis[]
  hiringDecisions       HiringDecision[]

  @@index([companyId])
  @@index([status])
}

model InterviewParticipant {
  id        String          @id @default(uuid())
  sessionId String
  userId    String?
  name      String
  email     String
  role      ParticipantRole @default(INTERVIEWER)
  joinedAt  DateTime?
  leftAt    DateTime?
  isHost    Boolean         @default(false)

  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
}

model InterviewTimeline {
  id          String   @id @default(uuid())
  sessionId   String
  eventType   String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model InterviewEvent {
  id        String   @id @default(uuid())
  sessionId String
  name      String
  payload   Json?
  createdAt DateTime @default(now())

  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model InterviewNote {
  id        String   @id @default(uuid())
  sessionId String
  authorId  String
  noteText  String
  isPrivate Boolean  @default(false)
  isPinned  Boolean  @default(false)
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([authorId])
}

// ==========================================
// INTERVIEW SCORECARD & EVALUATION ENGINE (SPRINT 3)
// ==========================================

enum ScorecardStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

enum RecommendationType {
  STRONG_HIRE
  HIRE
  BORDERLINE
  HOLD
  REJECT
}

model InterviewScorecard {
  id                   String             @id @default(uuid())
  companyId            String
  sessionId            String
  interviewerId        String
  candidateId          String
  title                String
  status               ScorecardStatus    @default(DRAFT)
  overallScore         Float?
  recommendation       RecommendationType?
  recommendationReason String?
  submittedAt          DateTime?
  reopenedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session              InterviewSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  interviewer          User               @relation("InterviewerScorecards", fields: [interviewerId], references: [id], onDelete: Cascade)
  candidate            User               @relation("CandidateScorecards", fields: [candidateId], references: [id], onDelete: Cascade)
  scores               EvaluationScore[]
  feedback             InterviewerFeedback?

  @@index([companyId])
  @@index([sessionId])
  @@index([interviewerId])
  @@index([candidateId])
}

model EvaluationScore {
  id            String             @id @default(uuid())
  scorecardId   String
  criterionName String
  score         Float
  maxScore      Float              @default(10.0)
  weight        Float              @default(1.0)
  comments      String?
  createdAt     DateTime           @default(now())

  scorecard     InterviewScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)

  @@index([scorecardId])
}

model InterviewerFeedback {
  id                    String             @id @default(uuid())
  scorecardId           String             @unique
  strengths             String[]           @default([])
  weaknesses            String[]           @default([])
  detailedNotes         String?
  privateFeedback       String?
  candidateVisibleNotes String?
  createdAt             DateTime           @default(now())

  scorecard             InterviewScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
}

// ==========================================
// AI INTERVIEW INTELLIGENCE ENGINE (SPRINT 4)
// ==========================================

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AIProviderType {
  RULE_BASED
  OPENAI
  GEMINI
  CLAUDE
  AZURE_OPENAI
  CUSTOM
}

model InterviewAIAnalysis {
  id                    String                   @id @default(uuid())
  companyId             String
  sessionId             String
  version               Int                      @default(1)
  provider              AIProviderType           @default(RULE_BASED)
  confidenceScore       Float                    @default(85.0)
  confidenceReason      String?
  overallRecommendation String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  company               Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session               InterviewSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  summary               InterviewSummary?
  insights              InterviewInsight[]
  risks                 InterviewRisk[]
  recommendations       InterviewRecommendation[]

  @@index([companyId])
  @@index([sessionId])
}

model InterviewSummary {
  id                     String              @id @default(uuid())
  analysisId             String              @unique
  candidateSummary       String
  interviewSummary       String
  technicalAnalysis      String?
  communicationAnalysis  String?
  problemSolvingAnalysis String?
  leadershipAnalysis     String?
  cultureFitAnalysis     String?
  createdAt              DateTime            @default(now())

  analysis               InterviewAIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model InterviewInsight {
  id                   String              @id @default(uuid())
  analysisId           String
  topStrengths         String[]            @default([])
  topWeaknesses        String[]            @default([])
  improvementAreas     String[]            @default([])
  recommendedTraining  String[]            @default([])
  suggestedNextFocus   String?
  hiringReadinessScore Float               @default(80.0)
  createdAt            DateTime            @default(now())

  analysis             InterviewAIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model InterviewRisk {
  id          String              @id @default(uuid())
  analysisId  String
  riskType    String
  severity    RiskSeverity        @default(LOW)
  description String
  mitigation  String?
  createdAt   DateTime            @default(now())

  analysis    InterviewAIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model InterviewRecommendation {
  id             String              @id @default(uuid())
  analysisId     String
  category       String
  recommendation String
  justification  String
  createdAt      DateTime            @default(now())

  analysis       InterviewAIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

// ==========================================
// HIRING DECISION WORKFLOW ENGINE (SPRINT 5)
// ==========================================

enum DecisionType {
  STRONG_HIRE
  HIRE
  HOLD
  REJECT
  RE_INTERVIEW
  NEXT_ROUND
  OFFER_READY
}

enum DecisionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  ON_HOLD
  ESCALATED
  OFFER_READY
  CLOSED
}

model HiringDecision {
  id                   String             @id @default(uuid())
  companyId            String
  applicationId        String
  sessionId            String?
  candidateId          String
  createdById          String
  decisionType         DecisionType
  status               DecisionStatus     @default(PENDING)
  reason               String
  overallScore         Float?
  aiRecommendation     String?
  version              Int                @default(1)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application          Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  session              InterviewSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  candidate            User               @relation("CandidateHiringDecisions", fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy            User               @relation("CreatedHiringDecisions", fields: [createdById], references: [id], onDelete: Cascade)

  approvals            DecisionApproval[]
  comments             DecisionComment[]
  history              DecisionHistory[]
  audits               DecisionAudit[]

  @@index([companyId])
  @@index([applicationId])
  @@index([sessionId])
  @@index([candidateId])
}

model DecisionApproval {
  id          String         @id @default(uuid())
  decisionId  String
  approverId  String
  level       Int            @default(1)
  status      DecisionStatus @default(PENDING)
  comments    String?
  actedAt     DateTime?
  createdAt   DateTime       @default(now())

  decision    HiringDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  approver    User           @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([approverId])
}

model DecisionComment {
  id          String         @id @default(uuid())
  decisionId  String
  authorId    String
  comment     String
  isPrivate   Boolean        @default(false)
  createdAt   DateTime       @default(now())

  decision    HiringDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([authorId])
}

model DecisionHistory {
  id          String         @id @default(uuid())
  decisionId  String
  actorId     String
  action      String
  fromStatus  DecisionStatus?
  toStatus    DecisionStatus
  notes       String?
  createdAt   DateTime       @default(now())

  decision    HiringDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  actor       User           @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([actorId])
}

model DecisionAudit {
  id          String         @id @default(uuid())
  decisionId  String
  actorId     String
  fieldName   String
  oldValue    String?
  newValue    String?
  reason      String?
  createdAt   DateTime       @default(now())

  decision    HiringDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  actor       User           @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([actorId])
}

// ==========================================
// EMPLOYEE ONBOARDING & PRE-JOINING FOUNDATION (PHASE 12 SPRINT 1)
// ==========================================

enum EmployeeLifecycle {
  PRE_JOINING
  JOINING_PENDING
  JOINED
  PROBATION
  CONFIRMED
  INACTIVE
  EXITED
}

enum OnboardingStatus {
  DRAFT
  IN_PROGRESS
  JOINING_PENDING
  COMPLETED
  CANCELLED
}

model OnboardingRecord {
  id                  String           @id @default(uuid())
  companyId           String
  offerId             String           @unique
  candidateId         String
  hrOwnerId           String
  managerId           String?
  status              OnboardingStatus @default(IN_PROGRESS)
  currentStage        String           @default("Pre-Joining Document Verification")
  progressPercentage  Float            @default(0.0)
  expectedJoiningDate DateTime
  actualJoiningDate   DateTime?
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  offer            Offer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  candidate        User              @relation("CandidateOnboardings", fields: [candidateId], references: [id], onDelete: Cascade)
  hrOwner          User              @relation("HROnboardings", fields: [hrOwnerId], references: [id], onDelete: Cascade)
  manager          User?             @relation("ManagerOnboardings", fields: [managerId], references: [id], onDelete: SetNull)
  joiningWorkflow  JoiningWorkflow?
  employeeProfile  EmployeeProfile?
  tasks            OnboardingTask[]

  @@index([companyId])
  @@index([candidateId])
  @@index([offerId])
  @@index([hrOwnerId])
  @@index([status])
}

model JoiningWorkflow {
  id                String           @id @default(uuid())
  onboardingId      String           @unique
  title             String           @default("Standard Joining Workflow")
  assignedHrId      String?
  assignedManagerId String?
  stages            Json?
  completedStages   Int              @default(0)
  totalStages       Int              @default(4)
  isCompleted       Boolean          @default(false)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  onboarding        OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
}

model EmployeeProfile {
  id                    String            @id @default(uuid())
  companyId             String
  userId                String            @unique
  onboardingId          String?           @unique
  employeeNumber        String
  employmentType        EmploymentType    @default(FULL_TIME)
  department            String
  designation           String
  managerId             String?
  joiningDate           DateTime
  probationPeriodMonths Int               @default(3)
  probationEndDate      DateTime?
  workLocation          String            @default("Head Office")
  workMode              WorkMode          @default(ONSITE)
  salary                Float?
  currency              String            @default("USD")
  lifecycleState        EmployeeLifecycle @default(PRE_JOINING)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  company          Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User                      @relation("UserProfile", fields: [userId], references: [id], onDelete: Cascade)
  onboarding       OnboardingRecord?         @relation(fields: [onboardingId], references: [id], onDelete: SetNull)
  manager          User?                     @relation("ManagerEmployees", fields: [managerId], references: [id], onDelete: SetNull)
  lifecycleHistory EmployeeLifecycleHistory[]

  @@unique([companyId, employeeNumber])
  @@index([companyId])
  @@index([userId])
  @@index([lifecycleState])
  @@index([department])
}

model EmployeeLifecycleHistory {
  id                String             @id @default(uuid())
  employeeProfileId String
  performedById     String
  fromState         EmployeeLifecycle?
  toState           EmployeeLifecycle
  reason            String?
  metadata          Json?
  createdAt         DateTime           @default(now())

  employeeProfile   EmployeeProfile    @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  performedBy       User               @relation(fields: [performedById], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@index([performedById])
}

// ==========================================
// ONBOARDING TASK ENGINE FOUNDATION
// ==========================================

enum TaskCategory {
  DOCUMENT
  BACKGROUND_CHECK
  IT_PROVISIONING
  ORIENTATION
  COMPLIANCE
  CUSTOM
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

model OnboardingTaskTemplate {
  id                 String       @id @default(uuid())
  companyId          String
  title              String
  description        String?
  category           TaskCategory @default(CUSTOM)
  isRequired         Boolean      @default(true)
  assignedRole       String       @default("HR")
  daysDueFromJoining Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks   OnboardingTask[]

  @@index([companyId])
  @@index([category])
}

model OnboardingTask {
  id            String                  @id @default(uuid())
  onboardingId  String
  templateId    String?
  title         String
  description   String?
  category      TaskCategory            @default(CUSTOM)
  status        TaskStatus              @default(PENDING)
  isRequired    Boolean                 @default(true)
  assignedToId  String?
  assignedRole  String                  @default("HR")
  dueDate       DateTime?
  completedAt   DateTime?
  completedById String?
  comments      String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  onboarding  OnboardingRecord        @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  template    OnboardingTaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assignedTo  User?                   @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  completedBy User?                   @relation("CompletedTasks", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([onboardingId])
  @@index([templateId])
  @@index([assignedToId])
  @@index([status])
}









