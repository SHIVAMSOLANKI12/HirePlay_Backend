generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(CANDIDATE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company[]
  refreshTokens RefreshToken[]
  applications  Application[]
  resumes       Resume[]
  activities    ApplicationActivity[]
  applicationNotes ApplicationNote[]
  activityLogs  ActivityLog[]
  candidateInterviews Interview[] @relation("CandidateInterviews")
  scheduledInterviews Interview[] @relation("ScheduledInterviews")
  interviewFeedbacks  InterviewFeedback[]
  interviewHistories  InterviewHistory[]
  candidateOffers     Offer[]       @relation("CandidateOffers")
  createdOffers       Offer[]       @relation("CreatedOffers")
  updatedOffers       Offer[]       @relation("UpdatedOffers")
  approvedOffers      Offer[]       @relation("ApprovedOffers")
  sentOffers          Offer[]       @relation("SentOffers")
  revokedOffers       Offer[]       @relation("RevokedOffers")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                 String      @id @default(cuid())
  name               String
  slug               String      @unique
  email              String?
  phone              String?
  website            String?
  industry           String?
  companySize        CompanySize
  logo               String?
  description        String?
  ownerId            String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?
  careerPagePublic   Boolean     @default(true)
  currency           String      @default("USD")
  dateFormat         String      @default("YYYY-MM-DD")
  defaultHiringStage String      @default("Applied")
  emailNotifications Boolean     @default(true)
  language           String      @default("en")
  smsNotifications   Boolean     @default(false)
  timeFormat         String      @default("24h")
  timezone           String      @default("UTC")
  owner              User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hrs                HR[]
  jobs               Job[]
  activityLogs       ActivityLog[]
  interviews         Interview[]
  offers             Offer[]
}

model HR {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String
  designation String
  password    String
  role        Role      @default(HR)
  status      String    @default("ACTIVE")
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  avatar      String?
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  refreshToken  String?
  refreshTokenExpiresAt DateTime?
  tokenVersion  Int       @default(1)
  lastLogoutAt  DateTime?
  passwordResetToken String?
  passwordResetExpiresAt DateTime?
  passwordChangedAt DateTime?
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR
  CANDIDATE
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum HRStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Job {
  id              String         @id @default(uuid())
  companyId       String
  createdBy       String
  title           String
  department      String
  employmentType  EmploymentType
  experienceLevel String?
  location        String
  workMode        WorkMode
  salaryMin       Float?
  salaryMax       Float?
  currency        String         @default("USD")
  description     String
  requirements    String
  benefits        String?
  status          JobStatus      @default(DRAFT)
  publishedAt     DateTime?
  applicationDeadline DateTime?


  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  activityLogs ActivityLog[]
  interviews   Interview[]
  offers       Offer[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

model Application {
  id          String            @id @default(uuid())
  candidateId String
  jobId       String
  resumeId    String?
  status      ApplicationStatus @default(APPLIED)
  resumeUrl   String?
  coverLetter String?
  appliedAt   DateTime          @default(now())
  withdrawnAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  candidate User   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume    Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  activities ApplicationActivity[]
  notes      ApplicationNote[]
  activityLogs ActivityLog[]
  interviews   Interview[]
  offer        Offer?

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model Resume {
  id           String    @id @default(uuid())
  candidateId  String
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  storageKey   String    @unique
  fileUrl      String
  isActive     Boolean   @default(true)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  candidate    User          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([candidateId])
  @@index([isActive])
}

enum ApplicationActivityAction {
  APPLICATION_CREATED
  APPLICATION_WITHDRAWN
  STATUS_CHANGED
  INTERVIEW_SCHEDULED
  INTERVIEW_RESCHEDULED
  INTERVIEW_CANCELLED
  INTERVIEW_COMPLETED
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_DRAFTED
  OFFER_APPROVED
  OFFER_REVOKED
  OFFER_EXPIRED
  APPLICATION_REJECTED
  APPLICATION_HIRED
  NOTE_ADDED
  RESUME_UPDATED
  PROFILE_UPDATED
  INTERVIEW_FEEDBACK_SUBMITTED
  INTERVIEW_DECISION_UPDATED
}

model ApplicationActivity {
  id            String                    @id @default(uuid())
  applicationId String
  performedBy   String
  action        ApplicationActivityAction
  oldStatus     ApplicationStatus?
  newStatus     ApplicationStatus?
  metadata      Json?
  
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  deletedAt     DateTime?

  application   Application               @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User                      @relation(fields: [performedBy], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([performedBy])
  @@index([action])
  @@index([createdAt])
}

model ApplicationNote {
  id            String      @id @default(uuid())
  applicationId String
  authorId      String
  note          String
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([authorId])
  @@index([createdAt])
}

model ActivityLog {
  id            String       @id @default(uuid())
  companyId     String?
  userId        String
  applicationId String?
  jobId         String?
  type          ActivityType
  title         String
  description   String
  metadata      Json?
  createdAt     DateTime     @default(now())

  // relations
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}

enum ActivityType {
  APPLICATION_SUBMITTED
  APPLICATION_WITHDRAWN
  APPLICATION_SHORTLISTED
  APPLICATION_REJECTED
  APPLICATION_REVIEWED
  INTERVIEW_SCHEDULED
  INTERVIEW_RESCHEDULED
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_DRAFTED
  OFFER_APPROVED
  OFFER_REVOKED
  OFFER_EXPIRED
  JOB_CREATED
  JOB_UPDATED
  JOB_CLOSED
  INTERVIEW_FEEDBACK_SUBMITTED
  INTERVIEW_CANCELLED
  INTERVIEW_DECISION_UPDATED
}

enum InterviewType {
  ONLINE
  OFFLINE
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum InterviewDecision {
  PENDING
  NEXT_ROUND
  SELECTED
  REJECTED
  ON_HOLD
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  companyId       String
  candidateId     String
  jobId           String
  scheduledById   String
  title           String
  description     String?
  type            InterviewType
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int
  timezone        String
  meetingLink     String?
  location        String?
  notes           String?
  
  roundNumber     Int             @default(1)
  roundName       String?
  parentInterviewId String?
  sequence        Int             @default(1)
  isFinalRound    Boolean         @default(false)
  completedAt     DateTime?
  
  decision        InterviewDecision @default(PENDING)
  decisionNotes   String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate       User            @relation("CandidateInterviews", fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scheduledBy     User            @relation("ScheduledInterviews", fields: [scheduledById], references: [id], onDelete: SetNull)
  parentInterview Interview?      @relation("InterviewRounds", fields: [parentInterviewId], references: [id], onDelete: Cascade)
  childRounds     Interview[]     @relation("InterviewRounds")
  feedbacks       InterviewFeedback[]
  history         InterviewHistory[]

  @@index([applicationId])
  @@index([companyId])
  @@index([candidateId])
  @@index([jobId])
  @@index([scheduledAt])
  @@index([parentInterviewId])
  @@index([status])
  @@index([roundNumber])
  @@index([decision])
  @@index([createdAt])
}

enum HiringRecommendation {
  STRONG_HIRE
  HIRE
  HOLD
  NO_HIRE
}

model InterviewFeedback {
  id                  String               @id @default(uuid())
  interviewId         String
  interviewerId       String
  overallRating       Float
  recommendation      HiringRecommendation
  technicalScore      Int?
  communicationScore  Int?
  problemSolvingScore Int?
  cultureFitScore     Int?
  strengths           String?
  weaknesses          String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  interview           Interview            @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer         User                 @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@unique([interviewId, interviewerId])
  @@index([interviewId])
  @@index([interviewerId])
  @@index([recommendation])
  @@index([createdAt])
}

enum InterviewHistoryAction {
  RESCHEDULED
  CANCELLED
  STATUS_CHANGED
}

model InterviewHistory {
  id              String                 @id @default(uuid())
  interviewId     String
  action          InterviewHistoryAction
  oldScheduledAt  DateTime?
  newScheduledAt  DateTime?
  oldStatus       InterviewStatus?
  newStatus       InterviewStatus?
  reason          String
  performedById   String
  metadata        Json?
  createdAt       DateTime               @default(now())

  interview       Interview              @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  performedBy     User                   @relation(fields: [performedById], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([performedById])
}

enum OfferStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

model Offer {
  id               String       @id @default(uuid())
  applicationId    String       @unique
  companyId        String
  candidateId      String
  jobId            String
  status           OfferStatus  @default(DRAFT)
  
  jobTitle         String
  department       String
  employmentType   EmploymentType
  salary           Float
  currency         String       @default("USD")
  joiningDate      DateTime
  location         String
  reportingManager String
  notes            String?
  validUntil       DateTime
  
  createdById      String
  updatedById      String?
  approvedById     String?
  sentById         String?
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  approvedAt       DateTime?
  sentAt           DateTime?
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  candidateResponseMessage String?
  rejectionReason  String?
  expiredAt        DateTime?
  revokedAt        DateTime?
  revokedById      String?
  revocationReason String?

  application      Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate        User         @relation("CandidateOffers", fields: [candidateId], references: [id], onDelete: Cascade)
  job              Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy        User         @relation("CreatedOffers", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User?        @relation("UpdatedOffers", fields: [updatedById], references: [id], onDelete: Restrict)
  approvedBy       User?        @relation("ApprovedOffers", fields: [approvedById], references: [id], onDelete: SetNull)
  sentBy           User?        @relation("SentOffers", fields: [sentById], references: [id], onDelete: SetNull)
  revokedBy        User?        @relation("RevokedOffers", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}
