generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(CANDIDATE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company[]

  refreshTokens       RefreshToken[]
  applications        Application[]
  resumes             Resume[]
  activities          ApplicationActivity[]
  applicationNotes    ApplicationNote[]
  activityLogs        ActivityLog[]
  candidateInterviews Interview[]           @relation("CandidateInterviews")
  scheduledInterviews Interview[]           @relation("ScheduledInterviews")
  createdInterviews   Interview[]           @relation("InterviewCreator")
  updatedInterviews   Interview[]           @relation("InterviewUpdater")

  interviewFeedbacks InterviewFeedback[]
  interviewHistories InterviewHistory[]
  candidateOffers    Offer[]             @relation("CandidateOffers")
  createdOffers      Offer[]             @relation("CreatedOffers")
  updatedOffers      Offer[]             @relation("UpdatedOffers")
  approvedOffers     Offer[]             @relation("ApprovedOffers")
  sentOffers         Offer[]             @relation("SentOffers")
  revokedOffers      Offer[]             @relation("RevokedOffers")
  performedTimelines OfferTimeline[]
  performedAuditLogs OfferAuditLog[]
  notifications      Notification[]
  notificationPreference NotificationPreference?
  createdAssessments Assessment[]        @relation("AssessmentCreator")
  assessmentAttempts AssessmentAttempt[]
  leaderboardEntries Leaderboard[]
  behaviours         AssessmentBehaviour[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  email              String?
  phone              String?
  website            String?
  industry           String?
  companySize        CompanySize
  logo               String?
  description        String?
  ownerId            String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  careerPagePublic   Boolean        @default(true)
  currency           String         @default("USD")
  dateFormat         String         @default("YYYY-MM-DD")
  defaultHiringStage String         @default("Applied")
  emailNotifications Boolean        @default(true)
  language           String         @default("en")
  smsNotifications   Boolean        @default(false)
  timeFormat         String         @default("24h")
  timezone           String         @default("UTC")
  owner              User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  hrs                HR[]
  jobs               Job[]
  activityLogs       ActivityLog[]
  interviews         Interview[]
  offers             Offer[]
  notifications      Notification[]
  notificationPreferences NotificationPreference[]
  assessments        Assessment[]
}

model HR {
  id                     String    @id @default(uuid())
  firstName              String
  lastName               String
  email                  String    @unique
  phone                  String
  designation            String
  password               String
  role                   Role      @default(HR)
  status                 String    @default("ACTIVE")
  isActive               Boolean   @default(true)
  lastLoginAt            DateTime?
  avatar                 String?
  companyId              String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?
  refreshToken           String?
  refreshTokenExpiresAt  DateTime?
  tokenVersion           Int       @default(1)
  lastLogoutAt           DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  passwordChangedAt      DateTime?
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR
  CANDIDATE
}

enum CompanySize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum HRStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Job {
  id                  String         @id @default(uuid())
  companyId           String
  createdBy           String
  title               String
  department          String
  employmentType      EmploymentType
  experienceLevel     String?
  location            String
  workMode            WorkMode
  salaryMin           Float?
  salaryMax           Float?
  currency            String         @default("USD")
  description         String
  requirements        String
  benefits            String?
  status              JobStatus      @default(DRAFT)
  publishedAt         DateTime?
  closedAt            DateTime?
  applicationDeadline DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  interviews   Interview[]
  offers       Offer[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([closedAt])
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum ApplicationSource {
  CAREERS_PAGE
  COMPANY_WEBSITE
  LINKEDIN
  NAUKRI
  INDEED
  REFERRAL
  CONSULTANCY
  CAMPUS
  MANUAL
  OTHER
}

model Application {
  id          String            @id @default(uuid())
  candidateId String
  jobId       String
  resumeId    String?
  status      ApplicationStatus @default(APPLIED)
  source      ApplicationSource @default(CAREERS_PAGE)
  resumeUrl   String?
  coverLetter String?
  appliedAt   DateTime          @default(now())
  withdrawnAt DateTime?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  candidate    User                  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job          Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume       Resume?               @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  activities   ApplicationActivity[]
  notes        ApplicationNote[]
  interviews   Interview[]
  offer        Offer?

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@index([jobId, status]) // Analytics Index
  @@index([jobId, source]) // Analytics Index
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum ParsingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiScoreStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Resume {
  id           String  @id @default(uuid())
  candidateId  String
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  storageKey   String  @unique
  fileUrl      String
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parsedData    Json?
  parsingStatus ParsingStatus @default(PENDING)
  parsedAt      DateTime?
  parserVersion String?
  parsingError  String?

  aiScore          Int?
  aiScoreVersion   String?
  aiScoreStatus    AiScoreStatus @default(PENDING)
  aiScoredAt       DateTime?
  aiScoreBreakdown Json?
  scoringProvider  String?

  candidate    User          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([candidateId, isActive, deletedAt]) // Optimized lookup for active candidate resumes
  @@index([createdAt]) // Optimized for date filtering
  @@index([parsingStatus]) // Optimized for parsing queues/status filtering
  @@index([parsedData], type: Gin) // Optimized for JSONB full-text and array searches
}

enum ApplicationActivityAction {
  APPLICATION_CREATED
  APPLICATION_WITHDRAWN
  STATUS_CHANGED
  INTERVIEW_SCHEDULED
  INTERVIEW_RESCHEDULED
  INTERVIEW_CANCELLED
  INTERVIEW_COMPLETED
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_DRAFTED
  OFFER_APPROVED
  OFFER_REVOKED
  OFFER_EXPIRED
  APPLICATION_REJECTED
  APPLICATION_HIRED
  NOTE_ADDED
  RESUME_UPDATED
  PROFILE_UPDATED
  INTERVIEW_FEEDBACK_SUBMITTED
  INTERVIEW_DECISION_UPDATED
}

model ApplicationActivity {
  id            String                    @id @default(uuid())
  applicationId String
  performedBy   String
  action        ApplicationActivityAction
  oldStatus     ApplicationStatus?
  newStatus     ApplicationStatus?
  metadata      Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [performedBy], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([performedBy])
  @@index([action])
  @@index([createdAt])
  @@index([performedBy, createdAt]) // Analytics Index
}

model ApplicationNote {
  id            String @id @default(uuid())
  applicationId String
  authorId      String
  note          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([authorId])
  @@index([createdAt])
}


enum InterviewType {
  ONLINE
  OFFLINE
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum InterviewDecision {
  PENDING
  NEXT_ROUND
  SELECTED
  REJECTED
  ON_HOLD
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  companyId       String
  candidateId     String
  jobId           String
  scheduledById   String
  title           String
  description     String?
  type            InterviewType
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int
  timezone        String
  meetingLink     String?
  location        String?
  notes           String?

  roundNumber       Int       @default(1)
  roundName         String?
  parentInterviewId String?
  sequence          Int       @default(1)
  isFinalRound      Boolean   @default(false)
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  rescheduledAt     DateTime?

  createdById String?
  updatedById String?

  decision      InterviewDecision @default(PENDING)
  decisionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application     Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate       User                @relation("CandidateInterviews", fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scheduledBy     User                @relation("ScheduledInterviews", fields: [scheduledById], references: [id], onDelete: SetNull)
  createdBy       User?               @relation("InterviewCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?               @relation("InterviewUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  parentInterview Interview?          @relation("InterviewRounds", fields: [parentInterviewId], references: [id], onDelete: Cascade)
  childRounds     Interview[]         @relation("InterviewRounds")
  feedbacks       InterviewFeedback[]
  history         InterviewHistory[]

  @@index([applicationId])
  @@index([companyId])
  @@index([candidateId])
  @@index([jobId])
  @@index([scheduledAt])
  @@index([parentInterviewId])
  @@index([status])
  @@index([roundNumber])
  @@index([decision])
  @@index([createdAt])
  @@index([companyId, jobId, status]) // Analytics Index
  @@index([scheduledById]) // Analytics Index
}

enum HiringRecommendation {
  STRONG_HIRE
  HIRE
  HOLD
  NO_HIRE
}

model InterviewFeedback {
  id                  String               @id @default(uuid())
  interviewId         String
  interviewerId       String
  overallRating       Float
  recommendation      HiringRecommendation
  technicalScore      Int?
  communicationScore  Int?
  problemSolvingScore Int?
  cultureFitScore     Int?
  strengths           String?
  weaknesses          String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer User      @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@unique([interviewId, interviewerId])
  @@index([interviewId])
  @@index([interviewerId])
  @@index([recommendation])
  @@index([createdAt])
}

enum InterviewHistoryAction {
  RESCHEDULED
  CANCELLED
  STATUS_CHANGED
}

model InterviewHistory {
  id             String                 @id @default(uuid())
  interviewId    String
  action         InterviewHistoryAction
  oldScheduledAt DateTime?
  newScheduledAt DateTime?
  oldStatus      InterviewStatus?
  newStatus      InterviewStatus?
  reason         String
  performedById  String
  metadata       Json?
  createdAt      DateTime               @default(now())

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  performedBy User      @relation(fields: [performedById], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([performedById])
}

enum OfferStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

model Offer {
  id            String      @id @default(uuid())
  applicationId String      @unique
  companyId     String
  candidateId   String
  jobId         String
  status        OfferStatus @default(DRAFT)

  jobTitle         String
  department       String
  employmentType   EmploymentType
  salary           Float
  currency         String         @default("USD")
  joiningDate      DateTime
  location         String
  reportingManager String
  notes            String?
  validUntil       DateTime

  createdById  String
  updatedById  String?
  approvedById String?
  sentById     String?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?
  approvedAt               DateTime?
  sentAt                   DateTime?
  acceptedAt               DateTime?
  rejectedAt               DateTime?
  candidateResponseMessage String?
  rejectionReason          String?
  expiredAt                DateTime?
  revokedAt                DateTime?
  revokedById              String?
  revocationReason         String?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidate   User        @relation("CandidateOffers", fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("CreatedOffers", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User?       @relation("UpdatedOffers", fields: [updatedById], references: [id], onDelete: Restrict)
  approvedBy  User?       @relation("ApprovedOffers", fields: [approvedById], references: [id], onDelete: SetNull)
  sentBy      User?       @relation("SentOffers", fields: [sentById], references: [id], onDelete: SetNull)
  revokedBy   User?       @relation("RevokedOffers", fields: [revokedById], references: [id], onDelete: SetNull)

  timelines OfferTimeline[]
  auditLogs OfferAuditLog[]

  @@index([companyId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([validUntil])
  @@index([deletedAt])
  @@index([companyId, jobId, status]) // Analytics Index
  @@index([createdById]) // Analytics Index
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String   @id @default(uuid())
  role         Role
  permissionId String
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

model OfferTimeline {
  id              String   @id @default(uuid())
  offerId         String
  type            String
  title           String
  description     String
  performedById   String?
  performedByRole String?
  createdAt       DateTime @default(now())

  offer       Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  performedBy User? @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([performedById])
}

model OfferAuditLog {
  id              String   @id @default(uuid())
  offerId         String
  action          String
  performedById   String?
  performedByRole String?
  field           String?
  oldValue        String?
  newValue        String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  offer       Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  performedBy User? @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([performedById])
}

enum NotificationType {
  INTERVIEW
  OFFER
  APPLICATION
  JOB
  AUTH
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
  PUSH
  WHATSAPP
  SLACK
}

enum NotificationStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  FAILED
  RETRYING
  CANCELLED
  READ
}

model Notification {
  id        String              @id @default(uuid())
  companyId String
  userId    String
  type      NotificationType
  channel   NotificationChannel
  title     String
  message   String
  status    NotificationStatus  @default(PENDING)
  payload   Json?
  isRead        Boolean             @default(false)
  
  // --- Email Engine Tracking Fields ---
  provider          String?
  messageId         String?
  providerResponse  String?
  failureReason     String?
  retryCount        Int                 @default(0)
  queuedAt          DateTime?
  processingAt      DateTime?
  sentAt            DateTime?
  failedAt          DateTime?
  lastRetryAt       DateTime?
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([isRead])
}

model NotificationPreference {
  id               String    @id @default(uuid())
  userId           String    @unique
  companyId        String
  emailEnabled     Boolean   @default(true)
  inAppEnabled     Boolean   @default(true)
  smsEnabled       Boolean   @default(false)
  pushEnabled      Boolean   @default(false)
  whatsappEnabled  Boolean   @default(false)
  marketingEnabled Boolean   @default(false)
  systemEnabled    Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

enum ActivityEntity {
  AUTH
  COMPANY
  HR
  JOB
  APPLICATION
  INTERVIEW
  OFFER
  NOTIFICATION
  SYSTEM
  RESUME
  ASSESSMENT
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  ASSIGN
  LOGIN
  LOGOUT
  PASSWORD_RESET
  APPLY
  WITHDRAW
  STATUS_CHANGE
  SCHEDULE
  RESCHEDULE
  CANCEL
  FEEDBACK
  APPROVE
  SEND
  ACCEPT
  REJECT
  PUBLISH
  CLOSE
  PREVIEW
  DOWNLOAD
  PARSE
  REPARSE
  PARSE_FAILED
  SEARCH
  SCORE
  RE_SCORE
  GENERATE
  START
  PAUSE
  RESUME
  SUBMIT
  FLAG
  VIEW
}

model ActivityLog {
  id              String         @id @default(uuid())
  companyId       String?
  userId          String?
  entityType      ActivityEntity
  entityId        String?
  action          ActivityAction
  oldValue        Json?
  newValue        Json?
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  performedByRole Role?

  createdAt       DateTime       @default(now())
  deletedAt       DateTime?
  retentionUntil  DateTime?
  archivedAt      DateTime?

  company         Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@index([retentionUntil])
  @@index([archivedAt])
}

// ==========================================
// ASSESSMENT MODULE
// ==========================================

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  EXPIRED
}

enum GameDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SessionState {
  CREATED
  READY
  RUNNING
  PAUSED
  SUBMITTED
  EXPIRED
  CANCELLED
  CHEAT_FLAGGED
}

enum CheatRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecommendationLevel {
  OUTSTANDING
  HIGHLY_RECOMMENDED
  RECOMMENDED
  AVERAGE
  NOT_RECOMMENDED
}

model Assessment {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String?
  status      AssessmentStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  scoringProfile Json? // Custom weights: { accuracy, efficiency, decisionSpeed, cheatPenalty }

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User     @relation("AssessmentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  games       AssessmentGame[]
  attempts    AssessmentAttempt[]
  behaviours  AssessmentBehaviour[]

  @@index([companyId])
  @@index([status])
}

model AssessmentGame {
  id           String   @id @default(uuid())
  assessmentId String
  gameType     String
  difficulty   GameDifficulty
  timeLimitMs  Int?
  config       Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  results      AssessmentResult[]
  sessions     GameSession[]

  @@index([assessmentId])
  @@index([gameType])
}

model AssessmentAttempt {
  id           String   @id @default(uuid())
  assessmentId String
  candidateId  String
  status           AttemptStatus @default(NOT_STARTED)
  score            Float?
  accuracy         Float?
  efficiency       Float?
  decisionSpeed    Float?
  recommendation   RecommendationLevel?
  scoreBreakdown   Json?
  rank             Int?           // Leaderboard rank snapshot
  
  startedAt        DateTime?
  completedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate    User       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  results      AssessmentResult[]
  sessions     GameSession[]
  behaviour    AssessmentBehaviour?

  @@index([assessmentId])
  @@index([candidateId])
  @@index([status])
  @@index([assessmentId, status, rank])
  @@index([assessmentId, candidateId, status])
}

model AssessmentResult {
  id          String   @id @default(uuid())
  attemptId   String
  gameId      String
  score           Float
  maxScore        Float
  accuracy        Float?
  efficiency      Float?
  decisionSpeed   Float?
  recommendation  RecommendationLevel?
  scoreBreakdown  Json?
  metadata        Json?

  createdAt       DateTime @default(now())

  attempt     AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  game        AssessmentGame    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([gameId])
  @@index([attemptId, score])
}

model GameSession {
  id                String         @id @default(uuid())
  attemptId         String
  gameId            String
  seedId            String?
  status            SessionState   @default(CREATED)
  
  // Anti-Cheat & Tracking
  cheatRiskScore    Int            @default(0)
  cheatRiskLevel    CheatRiskLevel @default(LOW)
  idleTimeMs        Int            @default(0)
  pauseCount        Int            @default(0)
  reconnectCount    Int            @default(0)

  startedAt         DateTime       @default(now())
  endedAt           DateTime?
  submittedAt       DateTime?

  attempt           AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  game              AssessmentGame    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seed              GameSeed?         @relation(fields: [seedId], references: [id], onDelete: SetNull)
  moves             GameMove[]
  cheatEvents       CheatEvent[]

  @@index([attemptId])
  @@index([gameId])
  @@index([attemptId, status])
}

model GameSeed {
  id               String   @id @default(uuid())
  assessmentId     String
  candidateId      String
  gameType         String
  difficulty       GameDifficulty
  
  seedData         Json
  hiddenSolution   Json
  hash             String   
  version          String
  metadata         Json?
  
  isUsed           Boolean  @default(false)
  createdAt        DateTime @default(now())

  sessions         GameSession[]

  @@unique([assessmentId, candidateId, gameType])
  @@index([gameType, difficulty])
  @@index([candidateId])
}

model GameMove {
  id             String      @id @default(uuid())
  sessionId      String
  moveNumber     Int
  action         String
  coordinates    Json?
  moveDurationMs Int
  metadata       Json?
  timestamp      DateTime    @default(now())

  session        GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, moveNumber])
  @@index([sessionId])
}

model CheatEvent {
  id          String      @id @default(uuid())
  sessionId   String
  eventType   String      
  metadata    Json?
  timestamp   DateTime    @default(now())
  
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}

model Leaderboard {
  id          String   @id @default(uuid())
  gameType    String
  candidateId String
  topScore    Float
  attemptsCount Int    @default(1)
  
  updatedAt   DateTime @updatedAt

  candidate   User     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([gameType, candidateId])
  @@index([gameType, topScore(sort: Desc)])
}

model AssessmentBehaviour {
  id                  String   @id @default(uuid())
  attemptId           String   @unique
  assessmentId        String
  candidateId         String

  thinkingSpeed       Float
  decisionQuality     Float
  problemSolving      Float
  planningAbility     Float
  consistency         Float
  riskTaking          Float
  accuracy            Float
  learningPattern     Float
  stressIndicator     Float
  confidenceIndicator Float

  behaviourSummary    Json     // Array of trait strings (e.g. ["Fast Logical Thinker", "High Accuracy"])
  metrics             Json?    // Move & timing metadata breakdown

  analysisVersion     String   @default("v1.0")
  analysisProvider    String   @default("RULE_BASED")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  attempt             AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  assessment          Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate           User              @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([candidateId])
  @@index([assessmentId, candidateId])
}


